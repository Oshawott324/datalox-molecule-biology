{
  "name": "@datalox/molecule-biology",
  "version": "0.1.0",
  "description": "Agent-native molecule biology workspace scaffold and deterministic sequence import.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "molecule-biology": "dist/src/cli/main.js"
  },
  "files": [
    "dist/src/**/*",
    "docs/mcp-host-setup.md",
    "docs/mcp-architecture-review.md",
    "fixtures/**/*",
    "skills/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "demo:diagnostic-digest:mcp": "npm run build --silent && node scripts/demo-diagnostic-digest-mcp.mjs",
    "demo:v1-review": "npm run build --silent && node scripts/demo-v1-review.mjs",
    "demo:puc19:mcp": "npm run build --silent && node scripts/demo-puc19-mcp.mjs",
    "eval:corpus:v0:check": "npm run build --silent && node scripts/eval-corpus-v0.mjs check",
    "eval:corpus:v0:generate": "npm run build --silent && node scripts/eval-corpus-v0.mjs generate",
    "replay:demo": "npm run build --silent && node dist/src/cli/main.js replay-demo --input-path fixtures/fasta/single.fa --molecule-id mol_replay_demo",
    "smoke:mcp": "npm run build --silent && node scripts/smoke-mcp.mjs",
    "smoke:mcp:cwd": "npm run build --silent && node scripts/smoke-mcp-cwd.mjs",
    "test": "vitest run",
    "validate:cr2:azimuth": "node scripts/validate-azimuth-reference.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
