{
  "name": "@datalox/molecule-biology",
  "version": "0.1.0",
  "description": "Agent-native molecule biology workspace scaffold and deterministic sequence import.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "molecule-biology": "dist/src/cli/main.js"
  },
  "files": [
    "dist/src/**/*",
    "docs/**/*.md",
    "fixtures/**/*"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "demo:puc19:mcp": "npm run build --silent && node scripts/demo-puc19-mcp.mjs",
    "replay:demo": "npm run build --silent && node dist/src/cli/main.js replay-demo --input-path fixtures/fasta/single.fa --molecule-id mol_replay_demo",
    "smoke:mcp": "npm run build --silent && node scripts/smoke-mcp.mjs",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.8"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  }
}
